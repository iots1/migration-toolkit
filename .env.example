# Environment Configuration for HIS Analyzer
# Copy this file to .env and fill in your values

# --- DATABASE CONFIGURATION (Required) ---
# PostgreSQL connection URL
# Format: postgresql://username:password@host:port/database_name
# Example for PostgreSQL 18:
DATABASE_URL=postgresql://his_user:your_secure_password@localhost:5432/his_analyzer

# --- APPLICATION SETTINGS (Optional) ---
HIS_ANALYTICS_ENV=development
LOG_LEVEL=INFO

# --- NOTES ---
# 1. Create database first: `CREATE DATABASE his_analyzer;`
# 2. Create user: `CREATE USER his_user WITH PASSWORD 'your_secure_password';`
# 3. Grant privileges: `GRANT ALL PRIVILEGES ON DATABASE his_analyzer TO his_user;`
# 4. Test connection: `psql -h localhost -U his_user -d his_analyzer`
